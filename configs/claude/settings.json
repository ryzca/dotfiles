{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "agentPushNotifEnabled": true,
  "alwaysThinkingEnabled": true,
  "defaultMode": "auto",
  "effortLevel": "high",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash \"${CLAUDE_CONFIG_DIR:-$HOME/.config/claude}/hooks/herdr-agent-state.sh\" session",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "bash \"${CLAUDE_CONFIG_DIR:-$HOME/.config/claude}/hooks/herdr-pane-title.sh\" sync",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "bash \"${CLAUDE_CONFIG_DIR:-$HOME/.config/claude}/hooks/herdr-pane-title.sh\" clear",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "model": "claude-fable-5[1m]",
  "permissions": {
    "allow": [
      "Read",
      "Edit(src/**)",
      "Edit(app/**)",
      "Edit(docs/**)",
      "Edit(_docs/**)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(pwd *)",
      "Bash(which *)",
      "Bash(ls *)",
      "Bash(df *)",
      "Bash(du *)",
      "Bash(history *)",
      "Bash(alias *)",
      "Bash(cat *)",
      "Bash(less *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(awk *)",
      "Bash(sed *)",
      "Bash(diff *)",
      "Bash(touch *)",
      "Bash(mkdir *)",
      "Bash(mv *)",
      "Bash(cp *)",
      "Bash(chmod *)",
      "Bash(chown *)",
      "Bash(tar *)",
      "Bash(zip *)",
      "Bash(unzip *)",
      "Bash(gzip *)",
      "Bash(gunzip *)",
      "Bash(ln *)",
      "Bash(source *)",
      "Bash(env *)",
      "Bash(ps *)",
      "Bash(top *)",
      "Bash(netstat *)",
      "Bash(ping *)",
      "Bash(lsof *)",
      "Bash(make *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git add *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git worktree *)",
      "Bash(git rev-parse *)",
      "Bash(git merge-base *)",
      "Bash(git symbolic-ref *)",
      "Bash(git wb *)",
      "Bash(gh repo view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh pr status *)",
      "Bash(gh pr checkout *)",
      "Bash(gh pr diff *)",
      "Bash(pnpm lint *)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:zenn.dev)",
      "WebFetch(domain:qiita.com)",
      "mcp__serena__*",
      "Bash(obsidian-doc-sync *)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(rm -rf *)",
      "Bash(git push *)",
      "Bash(git reset *)",
      "Bash(git rebase *)",
      "Read(.env.*)",
      "Read(id_rsa)",
      "Read(**/*token*)",
      "Read(**/*key*)",
      "Edit(.env*)",
      "Edit(**/secrets/**)",
      "Bash(rsync *)",
      "Bash(ssh *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(nc *)",
      "Bash(npm uninstall *)",
      "Bash(npm remove *)",
      "Bash(psql *)",
      "Bash(mysql *)",
      "Bash(mongod *)"
    ]
  },
  "preferredNotifChannel": "terminal_bell",
  "statusLine": {
    "command": "${CLAUDE_CONFIG_DIR}/statusline.sh",
    "type": "command"
  },
  "tui": "default"
}